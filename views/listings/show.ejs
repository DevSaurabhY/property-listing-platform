    <% layout("/layouts/boilerplate.ejs") %>

<div class="container my-4">
  <div class="row">
    <div class="col-lg-8 offset-lg-2">

      <!-- <h3 class="mb-3">Listing Details</h3> -->

      <div class="card shadow-sm">
        <div class="card-body">
          <h5 class="card-title mb-2"><%= listing.title %></h5>
            <div class="listing-image-wrapper mb-4">
                <img
                    src="<%= listing.image %>"
                    alt="<%= listing.title %>"
                    class="listing-image"
                >
            </div>

          <i>
            Hosted by <%= listing.owner ? listing.owner.username: "unknown" %>
          </i>
          <p class="card-text text-muted mb-3"><%= listing.description %></p>

          <ul class="list-group list-group-flush mb-3">
            <li class="list-group-item">
              <strong>Price:</strong> ₹<%= formatPrice(listing.price) %>
            </li>
            <li class="list-group-item">
              <strong>Location:</strong> <%= listing.location %>
            </li>
            <li class="list-group-item">
              <strong>Country:</strong> <%= listing.country %>
            </li>
          </ul>
          
          <% if (currUser && listing.owner && currUser._id.equals(listing.owner._id) ) { %> 
            <div class="d-flex gap-2">
            
              <a
                href="/listings/<%= listing._id %>/edit"
                class="btn btn-outline-primary">Edit
              </a>

              <form
                method="POST"
                action="/listings/<%= listing._id %>?_method=DELETE"
                >
                <button class="btn btn-danger">Delete</button>
              </form>
            </div>
          <% } %>

            <div>

              <% if (currUser) { %> 
                <hr class="my-4">
                <h4 class="mb-3">Leave a Review</h4>
                <form 

                  action="/listings/<%= listing._id %>/reviews" 
                  method="POST"
                  novalidate
                  class="mb-4 needs-validation"
                >

                <div class="mb-3">
                  <label class="form-label d-block">Rating</label>

                  <div class="star-rating">

                    <% for(let i = 1; i <= 5; i++){ %>
                      <input 
                        type="radio" 
                        name="review[rating]" 
                        value="<%= i %>" 
                        id="star<%= i %>"
                        required
                      >
                      <label for="star<%= i %>">★</label>
                    <% } %>

                  </div>
                </div>

                  <div class="mb-3">
                    <label for="comment" class="form-label">Comment</label>
                    <textarea 
                      name="review[comment]" 
                      id="comment" 
                      rows="3" 
                      class="form-control"
                      placeholder="Write your review..."
                      required
                    ></textarea>
                    <div class="invalid-feedback">
                            Please add comments!
                    </div>
                  </div>

                  <div class="text-center mb-3">
                    <button type="submit" class="btn btn-success">
                      Submit Review
                    </button>
                  </div>

                </form>
              <% } %>
              
              
              <h4 class="mt-4 mb-3">Reviews</h4>
              <div class="row">
                <% for(let review of listing.reviews){ %>

                  <div class="col-md-6 mb-3">
                    <div class="card shadow-sm h-100">

                      <div class="card-body">

                        <!-- User -->
                        <p class="fw-bold mb-1">
                          <i class="fa-solid fa-user"></i>
                          <%= review.author ? review.author.username : "Anonymous" %>
                        </p>

                        <!-- Rating -->
                        <div class="mb-2">
                          <% for(let i = 1; i <= 5; i++){ %>
                            <% if(i <= review.rating){ %>
                              <i class="fa-solid fa-star text-warning"></i>
                            <% } else { %>
                              <i class="fa-regular fa-star text-warning"></i>
                            <% } %>
                          <% } %>
                        </div>

                        <!-- Comment -->
                        <p class="text-muted">
                          <%= review.comment %>
                        </p>

                        <!-- Delete Button -->
                        <% if(currUser && review.author && currUser._id.equals(review.author._id)){ %>
                          <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                            <button class="btn btn-sm btn-danger">
                              Delete
                            </button>
                          </form>
                        <% } %>

                      </div>

                    </div>
                  </div>

                <% } %>
              </div>
        
          </div>

        </div>
      </div>

    </div>
  </div>
</div>
