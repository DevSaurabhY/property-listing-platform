<% layout("layouts/boilerplate.ejs") %>

<div class="row mt-3">
    <div class="col-8 offset-2">
        <h3>Listing Id: <%= listing._id %></h3>
        <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" class="needs-validation" novalidate enctype="multipart/form-data">
                <div class="mb-3 form-lable">
                    <label>Title</label>
                    <input class="form-control" name="listing[title]" type="text" value="<%= listing.title %>" id="validationCustom02" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                
                <div class="mb-3 form-lable">
                    <label for="">Description</label>
                    <input class="form-control" name="listing[description]" type="text" value="<%= listing.description %>" id="validationCustom02" required>
                    <div class="invalid-feedback">
                        Description required!
                    </div>
                </div>
                
                <div class="mb-4">
                    <label class="form-label fw-semibold">Current Image</label>

                    <div class="border rounded-4 overflow-hidden shadow-sm mb-3" style="max-width: 420px;">
                        <img 
                            src="<%= listing.image.url.replace('/upload','/upload/w_600') %>"
                            class="w-100"
                            style="height: 260px; aspect-ratio: 4 / 3; object-fit: cover;"
                        >
                    </div>

                    <label class="form-label fw-semibold">Upload New Image</label>
                    <input class="form-control" name="image" type="file">
                </div>
                                
                <div class="row mb-3">
                    <div class="md-3 form-lable col-md-4">
                        <label for="">Price</label>
                        <input class="form-control" name="listing[price]" type="text" value="<%= listing.price %>" id="validationCustom02" required>
                        <div class="invalid-feedback">
                            Enter Price!
                        </div>
                    </div>
                
                    <div class="md-3 form-lable col-md-4">
                        <label for="">Location</label>
                        <input class="form-control" name="listing[location]" type="text" value="<%= listing.location %>" id="validationCustom02" required>
                        <div class="invalid-feedback">
                            Please provide a valid location.
                        </div>
                    </div>
                </div>
                
                <div class="mb-3 for-lable">
                    <label for="">Country</label>
                    <input class="form-control" name="listing[country]" type="text" value="<%= listing.country %>" id="validationCustom02" required>
                    <div class="invalid-feedback">
                        Please provide a valid country.
                    </div>
                </div>

                <button class="btn btn-danger">Update</button>
                <br> <br>
        </form>
    </div>
</div>
